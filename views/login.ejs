<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Toko Portal | Toko Rooter</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@200;300;400;500;600;700;800&display=swap" rel="stylesheet">
</head>
<body class="bg-slate-950 flex items-center justify-center min-h-screen p-6 font-['Plus_Jakarta_Sans']">
  <div class="absolute inset-0 pointer-events-none overflow-hidden">
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] bg-purple-600 rounded-full blur-[180px] opacity-20"></div>
  </div>

  <div class="w-full max-w-md relative z-10">
    <div class="text-center mb-12">
      <div class="w-20 h-20 bg-purple-600 rounded-3xl flex items-center justify-center text-white text-3xl font-black mx-auto mb-6 shadow-2xl shadow-purple-600/30">T</div>
      <h1 class="text-3xl font-black text-white uppercase tracking-tighter">Toko Portal</h1>
      <p class="text-slate-500 text-sm font-bold uppercase tracking-widest mt-2">Authorized Access Only</p>
    </div>

    <div class="bg-white/5 backdrop-blur-xl border border-white/10 p-10 rounded-[2.5rem] shadow-2xl">
      <% if (error) { %>
        <div class="bg-red-500/10 border border-red-500/20 text-red-500 p-4 rounded-2xl text-xs font-bold uppercase tracking-widest mb-8 text-center">
          <%= error %>
        </div>
      <% } %>

      <form action="/login" method="POST" class="space-y-6">
        <div class="space-y-2">
          <label class="text-[10px] font-black uppercase tracking-[0.2em] text-slate-500 ml-4">Identifier</label>
          <input type="text" name="username" placeholder="Admin username" class="w-full bg-white/5 border border-white/10 rounded-2xl py-4 px-6 text-white font-bold focus:ring-2 focus:ring-purple-600 outline-none transition-all">
        </div>
        <div class="space-y-2">
          <label class="text-[10px] font-black uppercase tracking-[0.2em] text-slate-500 ml-4">Passkey</label>
          <input type="password" name="password" placeholder="••••••••" class="w-full bg-white/5 border border-white/10 rounded-2xl py-4 px-6 text-white font-bold focus:ring-2 focus:ring-purple-600 outline-none transition-all">
        </div>
        <button type="submit" class="w-full bg-purple-600 text-white py-5 rounded-2xl font-black uppercase tracking-widest text-sm hover:bg-white hover:text-purple-600 transition-all duration-500 shadow-xl shadow-purple-600/20 mt-4">
          Establish Connection
        </button>
      </form>
    </div>
    
    <div class="mt-12 text-center">
      <a href="/" class="text-slate-500 text-xs font-bold uppercase tracking-[0.3em] hover:text-white transition-colors">Return to Surface</a>
    </div>
  </div>
</body>
</html>
