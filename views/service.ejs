<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Our Services | ROOTER KING Plumbing Services</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <style>
    body { font-family: 'Plus Jakarta Sans', sans-serif; }
    .bg-gradient-valvoro { background: linear-gradient(135deg, #0f4392 0%, #1e3a8a 100%); }
    .rounded-valvoro { border-radius: 3.5rem; }
  </style>
</head>
<body class="bg-[#f8fafc] text-[#0f172a]">

  <%- include('partials/navbar') %>

  <!-- Hero Header -->
 <section class="max-w-[1500px] mx-auto px-4 py-4">
    <div class="bg-slate-950 rounded-[4rem] py-32 px-10 text-center text-white relative overflow-hidden">
      <div class="absolute inset-0 pointer-events-none">
        <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[800px] h-[800px] bg-purple-700 rounded-full blur-[200px] opacity-30"></div>
      </div>
      <div class="relative z-10 max-w-4xl mx-auto space-y-8">
        <p class="text-purple-400 font-bold uppercase tracking-[0.4em] text-xs">Locally Owned & Operated</p>
        <h1 class="text-7xl lg:text-8xl font-black tracking-tighter uppercase leading-none">Plumbing <br> Excellence.</h1>
      </div>
    </div>
  </section>

  <!-- Service List Section -->
  <section class="py-24 max-w-7xl mx-auto px-6">
    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
      <% services.forEach(service => { %>
        <div class="group bg-white rounded-[3rem] p-4 border border-slate-100 shadow-sm hover:shadow-2xl transition-all duration-500 hover:-translate-y-2 flex flex-col h-full">
           <div class="relative h-64 overflow-hidden rounded-[2.5rem] mb-8">
              <img src="<%= service.image %>" alt="<%= service.title %>" class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700">
             
           </div>
           
           <div class="px-6 pb-8 flex-1 flex flex-col space-y-4">
              <h3 class="text-2xl font-black text-[#0f172a] uppercase tracking-tighter"><%= service.title %></h3>
              <p class="text-slate-500 font-medium leading-relaxed mb-6 flex-1"><%= service.description %></p>
              
              <ul class="space-y-3 mb-8">
                <% (service.features || []).slice(0, 3).forEach(feature => { %>
                    <li class="flex items-center gap-3 font-bold text-slate-700 text-sm">
                       <div class="w-5 h-5 bg-blue-50 text-[#0f4392] rounded flex items-center justify-center">
                          <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"/></svg>
                       </div>
                       <%= feature %>
                    </li>
                 <% }) %>
              </ul>

              <a href="/contact" class="flex items-center justify-between bg-slate-50 group-hover:bg-[#22d3ee] group-hover:text-[#0f172a] p-4 rounded-2xl transition-all font-black uppercase text-sm">
                 <span>Enquire Now</span>
                 <div class="bg-white/50 rounded-full p-1 group-hover:bg-[#0f4392] group-hover:text-white transition-all">
                    <svg class="w-4 h-4 rotate-[-45deg]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M14 5l7 7m0 0l-7 7m7-7H3"/></svg>
                 </div>
              </a>
           </div>
        </div>
      <% }) %>
    </div>
  </section>

  <!-- CTA Banner -->
  <section class="pb-24 px-6 max-w-7xl mx-auto">
     <div class="bg-indigo-950  rounded-[3.5rem] p-12 lg:p-20 text-center text-white relative overflow-hidden">
        <div class="absolute top-0 right-0 w-96 h-96 bg-cyan-400 rounded-full bg-indigo-700 rounded-full blur-[200px] opacity-20 -mr-20 -mt-20"></div>
        <div class="relative z-10 max-w-3xl mx-auto">
           <h2 class="text-4xl lg:text-6xl font-black uppercase tracking-tighter mb-8 leading-none">Don't See What You Need?</h2>
           <p class="text-xl font-medium opacity-80 mb-10 leading-relaxed">
             Our expertise spans across all specialty plumbing tasks. Contact us for a custom quote on your unique project.
           </p>
           <a href="/contact" class="bg-[#22d3ee] text-[#0f172a] px-12 py-6 rounded-full font-black text-xl hover:bg-white transition-all inline-block shadow-2xl">
             Contact Specialist
           </a>
        </div>
     </div>
  </section>

  <%- include('partials/footer') %>

</body>
</html>
