            >

          </div>
        </div>

      </div>

    </div>

  </div>

</section>




  <!-- Narrative Section -->
  <section class="py-32 max-w-7xl mx-auto px-6">
    <div class="grid lg:grid-cols-2 gap-24 items-center">
      <div class="space-y-12">
        <div class="space-y-6 text-center lg:text-left">
          <h2 class="text-5xl font-extrabold text-slate-900 uppercase tracking-tighter leading-none">Innovation meets <br> Tradition.</h2>
          <p class="text-lg text-slate-500 font-medium leading-relaxed">
            Founded with a vision to eliminate the stress of plumbing disasters, Toko Rooter has evolved into a trusted choice for specialized repair and installation. We are locally owned and committed to serving our neighbours in Edmonton and surrounding communities.
          </p>
        </div>

        <div class="grid grid-cols-1 gap-6">
          <div class="p-8 bg-white rounded-[2rem] border border-slate-100 flex items-start gap-6 hover:shadow-2xl transition-all duration-500">
            <div class="w-16 h-16 bg-purple-50 rounded-2xl flex items-center justify-center text-purple-600 text-2xl shrink-0">
              <i class="fas fa-check-circle"></i>
            </div>
            <div>
              <h3 class="text-xl font-bold text-slate-900 uppercase tracking-tighter mb-2">Locally Owned</h3>
              <p class="text-slate-500 font-medium text-sm">We take pride in being a Canadian owned small business directly serving the Edmonton metro area.</p>
            </div>
          </div>
          <div class="p-8 bg-white rounded-[2rem] border border-slate-100 flex items-start gap-6 hover:shadow-2xl transition-all duration-500">
            <div class="w-16 h-16 bg-purple-50 rounded-2xl flex items-center justify-center text-purple-600 text-2xl shrink-0">
              <i class="fas fa-handshake"></i>
            </div>
            <div>
              <h3 class="text-xl font-bold text-slate-900 uppercase tracking-tighter mb-2">Honest Pricing</h3>
              <p class="text-slate-500 font-medium text-sm">Upfront quotes with no hidden surprises. We value your trust over everything else.</p>
            </div>
          </div>
        </div>
      </div>

      <div class="relative">
        <div class="grid grid-cols-2 gap-6">
          <img src="/images/home-tools2.jpg" class="rounded-[2.5rem] h-[500px] object-cover" alt="Plumbing Work">
          <img src="/images/home-tools1.jpg" class="rounded-[2.5rem] h-[500px] object-cover mt-12 shadow-2xl" alt="Plumbing Work">
        </div>
        <div class="absolute bottom-10 right-10 glass p-8 rounded-[2rem] text-center w-56 border border-slate-100">
          <p class="text-5xl font-extrabold text-purple-600">EDM.</p>
          <p class="text-[10px] font-bold uppercase tracking-[0.3em] text-slate-800 mt-2">Serving Since day one</p>
        </div>
      </div>
    </div>
  </section>

  <%- include('partials/footer') %>
  <%- include('partials/chatbot') %>
  
   <script>
const aboutSwiper = new Swiper('.aboutSwiper', {
  slidesPerView: 1,
  spaceBetween: 30,
  loop: true,

  autoplay: {
    delay: 3000,
    disableOnInteraction: false,
  },

  breakpoints: {
    640: {
      slidesPerView: 1,
    },
    768: {
      slidesPerView: 2,
    },
    1024: {
      slidesPerView: 3,
    },
  },
});  



new Swiper(".work-carousel", {

  loop: true,
  spaceBetween: 30,

  autoplay: {
    delay: 2500,
    disableOnInteraction: false,
  },

  breakpoints: {

    0: {
      slidesPerView: 1,
    },

    768: {
      slidesPerView: 2,
    },

    1024: {
      slidesPerView: 3,
    },

  },

});


</script>

