        Our Plumbing Work
      </h2>
    </div>

    <div class="swiper work-carousel">

      <div class="swiper-wrapper">

        <!-- Card 1 -->
        <div class="swiper-slide">
          <div class="bg-white p-3 rounded-[2rem] shadow-lg">

            <img
              src="/images/bathroom (1).jpg"
              class="w-full h-[260px] object-cover rounded-[1.5rem]"
            >

          </div>
        </div>

        <!-- Card 2 -->
        <div class="swiper-slide">
          <div class="bg-white p-3 rounded-[2rem] shadow-lg">

            <img
              src="/images/home-tools1.jpg"
              class="w-full h-[260px] object-cover rounded-[1.5rem]"
            >

          </div>
        </div>

        <!-- Card 3 -->
        <div class="swiper-slide">
          <div class="bg-white p-3 rounded-[2rem] shadow-lg">

            <img
              src="/images/home-tools2.jpg"
              class="w-full h-[260px] object-cover rounded-[1.5rem]"
            >

          </div>
        </div>

    

 <!-- Card 5 -->
        <div class="swiper-slide">
          <div class="bg-white p-3 rounded-[2rem] shadow-lg">

            <img
              src="/images/pro1.jpg"
              class="w-full h-[260px] object-cover rounded-[1.5rem]"
            >

          </div>
        </div>

         <!-- Card 6 -->
        <div class="swiper-slide">
          <div class="bg-white p-3 rounded-[2rem] shadow-lg">

            <img
              src="/images/pipe-inside2.jpg"
              class="w-full h-[260px] object-cover rounded-[1.5rem]"
            >

          </div>
        </div>

         <!-- Card 7 -->
        <div class="swiper-slide">
          <div class="bg-white p-3 rounded-[2rem] shadow-lg">

            <img
              src="/images/pro2.jpg"
              class="w-full h-[260px] object-cover rounded-[1.5rem]"
            >

          </div>
        </div>

              <!-- Card 7 -->
        <div class="swiper-slide">
          <div class="bg-white p-3 rounded-[2rem] shadow-lg">

            <img
              src="/images/project6.jpg"
              class="w-full h-[260px] object-cover rounded-[1.5rem]"
            >

          </div>
        </div>

              <!-- Card 7 -->
        <div class="swiper-slide">
          <div class="bg-white p-3 rounded-[2rem] shadow-lg">

            <img
              src="/images/project9.jpg"
              class="w-full h-[260px] object-cover rounded-[1.5rem]"
            >

          </div>
        </div>

        <div class="swiper-slide">
          <div class="bg-white p-3 rounded-[2rem] shadow-lg">

