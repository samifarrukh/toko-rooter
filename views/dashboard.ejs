<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Mission Control | Rooter King Dashboard</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@200;300;400;500;600;700;800&family=JetBrains+Mono:wght@400;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
  <style>
    body { font-family: 'Plus Jakarta Sans', sans-serif; }
    .mono { font-family: 'JetBrains Mono', monospace; }
    .glass {
      background: rgba(255, 255, 255, 0.7);
      backdrop-filter: blur(12px);
      -webkit-backdrop-filter: blur(12px);
    }
  </style>
</head>
<body class="bg-slate-50 min-h-screen font-['Plus_Jakarta_Sans'] text-slate-900">

  <nav class="bg-white/80 backdrop-blur-md border-b border-slate-200 px-4 md:px-12 py-5 flex items-center justify-between sticky top-0 z-50">
    <div class="flex items-center gap-4 md:gap-8">
      <a href="/" class="flex items-center group">
        <div class="h-10 px-4 bg-slate-900 text-white flex items-center justify-center rounded-xl font-black italic tracking-tighter text-lg group-hover:bg-purple-600 transition-colors">
         TOKO <span class="text-purple-400 group-hover:text-white"> ROOTER</span>
        </div>
      </a>
      <div class="h-8 w-px bg-slate-200 hidden sm:block"></div>
      <div>
        <p class="text-xs font-black text-slate-400 uppercase tracking-[0.2em]">Dashboard</p>
        <p class="text-lg font-black text-slate-950 tracking-tight hidden sm:block">Mission Control</p>
      </div>
    </div>
    
    <div class="flex items-center gap-4 md:gap-8">
      <div class="text-right hidden sm:block border-r border-slate-200 pr-8 mr-2">
        <p class="text-sm font-black text-slate-950 uppercase tracking-tight italic">Administrator</p>
        <div class="flex items-center justify-end gap-2 mt-0.5">
           <div class="w-2 h-2 bg-emerald-500 rounded-full animate-pulse"></div>
           <p class="text-[10px] font-bold text-slate-400 uppercase tracking-widest">Active Session</p>
        </div>
      </div>
      <a href="/logout" class="bg-slate-100 text-slate-600 px-5 py-3 rounded-2xl font-black text-sm hover:bg-red-50 hover:text-red-600 transition-all flex items-center gap-2">
        <span class="hidden md:inline uppercase tracking-widest text-xs">Shutdown</span>
        <i class="fas fa-power-off"></i>
      </a>
    </div>
  </nav>

  <main class="max-w-7xl mx-auto px-4 md:px-12 py-8 md:py-16">
    <!-- Header Section -->
    <div class="flex flex-col md:flex-row md:items-end justify-between gap-6 mb-12">
        <div>
            <h1 class="text-4xl md:text-6xl font-black text-slate-950 tracking-tighter mb-4 italic">
                Awaiting <span class="text-purple-600">Operations.</span>
            </h1>
            <p class="text-lg text-slate-500 font-medium max-w-xl">
                Real-time stream of incoming service requests and emergency dispatches.
            </p>
        </div>
        <div class="flex gap-3">
             <button class="bg-white border-2 border-slate-200 px-6 py-4 rounded-2xl text-sm font-black uppercase tracking-widest hover:border-slate-900 transition-all">
                Sync Logs
             </button>
             <button class="bg-slate-950 text-white px-6 py-4 rounded-2xl text-sm font-black uppercase tracking-widest shadow-xl shadow-slate-200 hover:bg-purple-700 transition-all">
                Export Data
             </button>
        </div>
    </div>

    <!-- Stats Grid -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 md:gap-10 mb-16">
      <div class="bg-white p-10 rounded-[3rem] border-2 border-slate-100 shadow-sm relative overflow-hidden group">
        <div class="relative z-10">
            <p class="text-xs font-black uppercase tracking-[0.2em] text-slate-400 mb-4">Total Fleet Tasks</p>
            <p class="text-7xl font-black text-slate-950 tracking-tighter"><%= booking.length %></p>
        </div>
        <div class="absolute -bottom-6 -right-6 text-slate-50 text-9xl group-hover:scale-110 transition-transform duration-700"><i class="fas fa-thumbtack"></i></div>
      </div>
      
      <div class="bg-white p-10 rounded-[3rem] border-2 border-slate-100 shadow-sm relative overflow-hidden group">
        <div class="relative z-10">
            <p class="text-xs font-black uppercase tracking-[0.2em] text-slate-400 mb-4">Urgent Dispatch</p>
            <p class="text-7xl font-black text-purple-600 tracking-tighter"><%= booking.filter(b => b.status === 'Pending').length %></p>
        </div>
        <div class="absolute -bottom-6 -right-6 text-purple-50 text-9xl group-hover:scale-110 transition-transform duration-700"><i class="fas fa-bolt-lightning"></i></div>
      </div>

      <div class="bg-slate-900 p-10 rounded-[3rem] shadow-2xl relative overflow-hidden text-white group">
        <div class="relative z-10 h-full flex flex-col justify-between">
            <div>
                <p class="text-xs font-black uppercase tracking-[0.2em] text-slate-400 mb-4 text-purple-400">Network Status</p>
                <p class="text-4xl font-black tracking-tight uppercase italic underline decoration-purple-600 decoration-4">Operational</p>
            </div>
            <div class="flex items-center gap-3 mt-8 bg-white/5 w-fit px-4 py-2 rounded-full border border-white/10">
              <div class="w-2.5 h-2.5 bg-emerald-400 rounded-full animate-pulse shadow-glow shadow-emerald-500/50"></div> 
              <span class="text-[10px] font-black uppercase tracking-[0.2em]">Cloud Core Online</span>
            </div>
        </div>
        <div class="absolute -top-10 -right-10 text-slate-800 text-9xl group-hover:text-purple-900 transition-colors duration-700"><i class="fas fa-microchip"></i></div>
      </div>
    </div>

    <!-- Data Table Section -->
    <div class="bg-white rounded-[4rem] border-2 border-slate-100 shadow-2xl shadow-slate-200/50 overflow-hidden">
      <div class="px-8 md:px-12 py-10 border-b border-slate-100 flex flex-col md:flex-row md:items-center justify-between gap-6">
        <div>
            <h3 class="text-3xl font-black text-slate-950 uppercase tracking-tighter italic">Fleet Queue</h3>
            <p class="text-sm font-bold text-slate-400 mt-1 uppercase tracking-widest px-1">Processing incoming data packets</p>
        </div>
        <div class="flex bg-slate-100 p-1.5 rounded-2xl w-fit">
            <button class="bg-white text-slate-950 px-6 py-2.5 rounded-xl text-xs font-black uppercase tracking-widest shadow-sm">Live Feed</button>
            <button class="text-slate-400 px-6 py-2.5 rounded-xl text-xs font-black uppercase tracking-widest hover:text-slate-600 transition-colors">Archived</button>
        </div>
      </div>

      <div class="overflow-x-auto">
        <table class="w-full text-left min-w-[800px]">
          <thead>
            <tr class="text-xs font-black uppercase tracking-[0.2em] text-slate-400 bg-slate-50/50">
              <th class="px-12 py-8">Service Target</th>
              <th class="px-6 py-8">Objective</th>
              <th class="px-6 py-8">Dispatch Time</th>
              <th class="px-6 py-8">Vector Status</th>
              <th class="px-12 py-8 text-right">System Control</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-slate-50">
            <% booking.sort((a,b) => new Date(b.createdAt) - new Date(a.createdAt)).forEach(item => { %>
              <tr class="hover:bg-slate-50/80 transition-all group">
                <td class="px-12 py-10">
                  <div class="flex items-center gap-4">
                      <div class="w-12 h-12 rounded-2xl bg-slate-900 text-white flex items-center justify-center font-black text-lg shadow-lg shadow-slate-200">
                          <%= item.name.charAt(0).toUpperCase() %>
                      </div>
                      <div>
                          <p class="text-lg font-black text-slate-950 leading-tight mb-1 tracking-tight"><%= item.name %></p>
                          <p class="text-xs font-bold text-slate-400 tracking-wider uppercase"><%= item.phone %> • <%= item.email %></p>
                      </div>
                  </div>
                </td>
                <td class="px-6 py-10">
                  <div class="flex flex-col gap-2">
                    <span class="inline-block bg-purple-100 text-purple-700 px-3 py-1 rounded-full text-[10px] font-black uppercase tracking-widest w-fit"><%= item.service %></span>
                    <p class="text-sm font-semibold text-slate-600 max-w-xs leading-relaxed"><%= item.message %></p>
                  </div>
                </td>
                <td class="px-6 py-10 mono text-xs font-bold text-slate-400 uppercase">
                  <%= new Date(item.createdAt).toLocaleDateString() %><br>
                  <span class="text-slate-900 text-[10px]"><%= new Date(item.createdAt).toLocaleTimeString([], {hour: '2-digit', minute:'2-digit'}) %></span>
                </td>
                <td class="px-6 py-10">
                  <form action="/status/<%= item._id %>" method="POST">
                    <div class="relative group/select">
                        <select name="status" onchange="this.form.submit()" 
                            class="appearance-none bg-slate-100 border-2 border-transparent rounded-2xl py-3 pl-5 pr-10 text-xs font-black uppercase tracking-widest text-slate-700 focus:ring-0 focus:border-purple-600 hover:bg-white hover:border-slate-300 transition-all cursor-pointer">
                          <option value="Pending" <%= item.status === 'Pending' ? 'selected' : '' %>>Pending</option>
                          <option value="Approved" <%= item.status === 'Approved' ? 'selected' : '' %>>Approved</option>
                          <option value="Rejected" <%= item.status === 'Rejected' ? 'selected' : '' %>>Rejected</option>
                          <option value="Completed" <%= item.status === 'Completed' ? 'selected' : '' %>>Completed</option>
                        </select>
                        <div class="absolute right-4 top-1/2 -translate-y-1/2 pointer-events-none text-slate-400">
                            <i class="fas fa-chevron-down text-[10px]"></i>
                        </div>
                    </div>
                  </form>
                </td>
                <td class="px-12 py-10 text-right">
                  <div class="flex items-center justify-end gap-3 opacity-0 group-hover:opacity-100 transition-all translate-x-4 group-hover:translate-x-0">
                    <form action="/delete/<%= item._id %>" method="POST" onsubmit="return confirm('Archive this assignment forever?')">
                      <button class="w-12 h-12 bg-white text-slate-400 rounded-2xl flex items-center justify-center hover:bg-red-50 hover:text-red-600 transition-all border border-slate-100 shadow-sm">
                        <i class="far fa-trash-alt text-lg"></i>
                      </button>
                    </form>
                  </div>
                </td>
              </tr>
            <% }) %>
            <% if (booking.length === 0) { %>
              <tr>
                <td colspan="5" class="px-12 py-32 text-center">
                  <div class="w-24 h-24 bg-slate-50 rounded-[2rem] flex items-center justify-center text-slate-200 text-4xl mx-auto mb-8 shadow-inner">
                    <i class="fas fa-inbox"></i>
                  </div>
                  <p class="text-xl font-black text-slate-400 uppercase tracking-widest italic">All Quiet on the Base</p>
                  <p class="text-slate-400 mt-2 font-medium">No incoming signals detected at this time.</p>
                </td>
              </tr>
            <% } %>
          </tbody>
        </table>
      </div>
      
      <div class="bg-slate-50 px-12 py-6 border-t border-slate-100 text-center">
          <p class="text-[10px] font-black text-slate-400 uppercase tracking-[0.4em]">End of Transmission</p>
      </div>
    </div>
  </main>
</body>
</html>
